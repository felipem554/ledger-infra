# Copy this file to .env (which is git-ignored) and adjust for your local environment.
# All variables have safe defaults and the stack works without a .env file.

POSTGRES_USER=ledger
POSTGRES_PASSWORD=ledger
POSTGRES_DB=ledger

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Override the pre-built ledger-service image (e.g. to test a local build):
# LEDGER_SERVICE_IMAGE=ghcr.io/felipem554/ledger-service:latest
